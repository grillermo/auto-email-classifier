RAILS_ENV=development
PORT=3000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=email_rules_development
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/email_rules_development

APP_BASE_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. By default the app uses ~/.credentials/gmail-modify-token.yaml
# GOOGLE_OAUTH_TOKEN_PATH=/Users/grillermo/.credentials/gmail-modify-token.yaml

GMAIL_POLL_INTERVAL_SECONDS=60
GMAIL_PRIMARY_QUERY=in:inbox
AUTO_RULE_FORWARD_QUERY=is:unread in:inbox from:me (subject:"Fwd:" OR subject:"FW:")
AUTO_RULE_DEFAULT_REMOVE_LABEL=INBOX
AUTO_RULE_REPLY_FROM=me
