RAILS_ENV=development
PORT=3000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=email_rules_development
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/email_rules_development

APP_BASE_URL=http://localhost:3000

GOOGLE_OAUTH_CLIENT_PATH=/Users/grillermo/c/email-classifier/rules_editor/config/google_oauth_client.json
GOOGLE_OAUTH_TOKEN_PATH=/Users/grillermo/c/email-classifier/rules_editor/tmp/gmail_token.json

GMAIL_POLL_INTERVAL_SECONDS=60
GMAIL_PRIMARY_QUERY=is:unread in:inbox
AUTO_RULE_FORWARD_QUERY=is:unread in:inbox from:me (subject:"Fwd:" OR subject:"FW:")
AUTO_RULE_DEFAULT_REMOVE_LABEL=INBOX
AUTO_RULE_REPLY_FROM=me
