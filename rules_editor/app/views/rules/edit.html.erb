<% content_for :title, "Edit #{@rule.name}" %>

<% conditions = Array(@definition["conditions"]) %>
<% actions = Array(@definition["actions"]) %>
<% conditions = [{ "field" => "sender", "operator" => "contains", "value" => "", "case_sensitive" => false }] if conditions.empty? %>
<% actions = [{ "type" => "mark_read" }] if actions.empty? %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-semibold">Edit Rule</h1>
    <p class="text-sm text-slate-600"><%= @rule.name %></p>
  </div>
  <%= link_to "Back", rule_path(@rule), class: "rounded border border-slate-300 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
</div>

<%= form_with model: @rule, url: rule_path(@rule), method: :patch, class: "space-y-6" do |f| %>
  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="mb-4 text-lg font-semibold">Basics</h2>

    <div class="grid gap-4 md:grid-cols-3">
      <div class="md:col-span-2">
        <%= f.label :name, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, required: true, class: "w-full rounded border border-slate-300 px-3 py-2" %>
      </div>

      <div>
        <%= f.label :priority, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= f.number_field :priority, min: 1, required: true, class: "w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
    </div>

    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700" for="rule_match_mode">Match mode</label>
        <select id="rule_match_mode" name="rule[match_mode]" class="w-full rounded border border-slate-300 px-3 py-2">
          <option value="all" <%= "selected" if @definition["match_mode"].to_s != "any" %>>all conditions</option>
          <option value="any" <%= "selected" if @definition["match_mode"].to_s == "any" %>>any condition</option>
        </select>
      </div>

      <div class="flex items-end">
        <label class="inline-flex items-center gap-2 text-sm">
          <%= f.check_box :active %>
          <span>Active</span>
        </label>
      </div>
    </div>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">Conditions</h2>
      <button type="button" id="add-condition" class="rounded bg-slate-200 px-3 py-2 text-sm font-medium text-slate-800 hover:bg-slate-300">Add condition</button>
    </div>

    <div id="conditions-container" data-next-index="<%= conditions.length %>" class="space-y-3">
      <% conditions.each_with_index do |condition, index| %>
        <div class="condition-row grid gap-2 rounded border border-slate-200 bg-slate-50 p-3 md:grid-cols-[1fr_1fr_2fr_auto_auto]">
          <select name="rule[conditions_attributes][<%= index %>][field]" class="rounded border border-slate-300 px-2 py-1">
            <% ["sender", "subject", "body"].each do |field| %>
              <option value="<%= field %>" <%= "selected" if condition["field"] == field %>><%= field %></option>
            <% end %>
          </select>

          <select name="rule[conditions_attributes][<%= index %>][operator]" class="rounded border border-slate-300 px-2 py-1">
            <% ["exact", "contains"].each do |operator| %>
              <option value="<%= operator %>" <%= "selected" if condition["operator"] == operator %>><%= operator %></option>
            <% end %>
          </select>

          <input type="text" name="rule[conditions_attributes][<%= index %>][value]" value="<%= condition["value"] %>" class="rounded border border-slate-300 px-2 py-1" required>

          <label class="inline-flex items-center gap-1 text-xs text-slate-700">
            <input type="hidden" name="rule[conditions_attributes][<%= index %>][case_sensitive]" value="false">
            <input type="checkbox" name="rule[conditions_attributes][<%= index %>][case_sensitive]" value="true" <%= "checked" if condition["case_sensitive"] %>>
            case sensitive
          </label>

          <button type="button" class="remove-row rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100">Remove</button>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">Actions</h2>
      <button type="button" id="add-action" class="rounded bg-slate-200 px-3 py-2 text-sm font-medium text-slate-800 hover:bg-slate-300">Add action</button>
    </div>

    <div id="actions-container" data-next-index="<%= actions.length %>" class="space-y-3">
      <% actions.each_with_index do |action, index| %>
        <div class="action-row grid gap-2 rounded border border-slate-200 bg-slate-50 p-3 md:grid-cols-[1fr_2fr_auto]">
          <select name="rule[actions_attributes][<%= index %>][type]" class="action-type rounded border border-slate-300 px-2 py-1">
            <% ["add_label", "remove_label", "mark_read", "trash"].each do |type| %>
              <option value="<%= type %>" <%= "selected" if action["type"] == type %>><%= type %></option>
            <% end %>
          </select>

          <input type="text" name="rule[actions_attributes][<%= index %>][label]" value="<%= action["label"] %>" class="action-label rounded border border-slate-300 px-2 py-1" placeholder="Label name (only for add/remove label)">

          <button type="button" class="remove-row rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100">Remove</button>
        </div>
      <% end %>
    </div>
  </section>

  <div class="flex flex-wrap gap-3">
    <button type="submit" name="commit_action" value="save" class="rounded bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700">Save</button>
    <button type="submit" name="commit_action" value="save_and_apply" class="rounded bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700">Save and apply rule</button>
  </div>
<% end %>

<template id="condition-row-template">
  <div class="condition-row grid gap-2 rounded border border-slate-200 bg-slate-50 p-3 md:grid-cols-[1fr_1fr_2fr_auto_auto]">
    <select name="rule[conditions_attributes][__INDEX__][field]" class="rounded border border-slate-300 px-2 py-1">
      <option value="sender">sender</option>
      <option value="subject">subject</option>
      <option value="body">body</option>
    </select>

    <select name="rule[conditions_attributes][__INDEX__][operator]" class="rounded border border-slate-300 px-2 py-1">
      <option value="exact">exact</option>
      <option value="contains" selected>contains</option>
    </select>

    <input type="text" name="rule[conditions_attributes][__INDEX__][value]" class="rounded border border-slate-300 px-2 py-1" required>

    <label class="inline-flex items-center gap-1 text-xs text-slate-700">
      <input type="hidden" name="rule[conditions_attributes][__INDEX__][case_sensitive]" value="false">
      <input type="checkbox" name="rule[conditions_attributes][__INDEX__][case_sensitive]" value="true">
      case sensitive
    </label>

    <button type="button" class="remove-row rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100">Remove</button>
  </div>
</template>

<template id="action-row-template">
  <div class="action-row grid gap-2 rounded border border-slate-200 bg-slate-50 p-3 md:grid-cols-[1fr_2fr_auto]">
    <select name="rule[actions_attributes][__INDEX__][type]" class="action-type rounded border border-slate-300 px-2 py-1">
      <option value="add_label">add_label</option>
      <option value="remove_label">remove_label</option>
      <option value="mark_read">mark_read</option>
      <option value="trash">trash</option>
    </select>

    <input type="text" name="rule[actions_attributes][__INDEX__][label]" class="action-label rounded border border-slate-300 px-2 py-1" placeholder="Label name (only for add/remove label)">

    <button type="button" class="remove-row rounded border border-slate-300 px-3 py-1 text-xs text-slate-700 hover:bg-slate-100">Remove</button>
  </div>
</template>
