<div class="max-w-2xl mx-auto mt-10">
  <div class="bg-surface-container-lowest border border-outline-variant p-8 rounded-2xl shadow-sm">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-container text-on-primary-container text-xs font-semibold uppercase tracking-[0.2em]">
      Gmail setup
    </div>

    <h1 class="mt-5 text-3xl font-bold text-on-surface font-headline">Connect a Gmail account</h1>
    <p class="mt-3 text-sm leading-6 text-on-surface-variant">
      Continue with Google to add a Gmail account for rule previews, syncing, and future automations.
      You can skip this for now and add it later from the header.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <%= link_to "Continue with Google", gmail_oauth_authorize_path, class: "inline-flex items-center justify-center bg-primary hover:bg-primary-dim text-on-primary font-semibold py-3 px-5 rounded-full transition-colors duration-200" %>
      <%= link_to "Skip for now", root_path, class: "inline-flex items-center justify-center border border-outline-variant text-on-surface font-semibold py-3 px-5 rounded-full transition-colors duration-200 hover:bg-surface-container-low" %>
    </div>
  </div>
</div>
